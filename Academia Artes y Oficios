<script>
document.addEventListener("DOMContentLoaded", function(){
  const duration = 5 * 60 * 1000;
  const storageKey = "academiaPromoEndTime";
  let endTime = localStorage.getItem(storageKey);

  if(!endTime){
    endTime = Date.now() + duration;
    localStorage.setItem(storageKey, endTime);
  }

  const timerEls = document.querySelectorAll(".countdown");
  const buttons = document.querySelectorAll(".promo-action");
  const expiredBlocks = document.querySelectorAll(".expired-message");

  function updateTimer(){
    const distance = Number(endTime) - Date.now();

    if(distance <= 0){
      timerEls.forEach(el => el.textContent = "00:00");
      buttons.forEach(btn => {
        btn.classList.remove("btn-whatsapp","btn-warning","pulse");
        btn.classList.add("btn-secondary");
        btn.textContent = "Promoción finalizada";
        btn.removeAttribute("href");
      });
      expiredBlocks.forEach(el => el.classList.remove("d-none"));
      clearInterval(interval);
      return;
    }

    const minutes = Math.floor(distance / 1000 / 60);
    const seconds = Math.floor((distance / 1000) % 60);
    const text = `${String(minutes).padStart(2,"0")}:${String(seconds).padStart(2,"0")}`;
    timerEls.forEach(el => el.textContent = text);
  }

  updateTimer();
  const interval = setInterval(updateTimer, 1000);
});
</script>
</body></html>

